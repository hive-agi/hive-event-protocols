{:paths ["src" "resources"]
 :deps {org.clojure/clojure {:mvn/version "1.12.1"}

        ;; FSM engine — compile, run, sub-FSM composition, FX
        io.github.hive-agi/hive-events {:mvn/version "0.5.5"}

        ;; Result ADT — ok/err railway for handler returns
        io.github.hive-agi/hive-dsl {:mvn/version "0.5.6"}}

 :aliases
 {
  ;; :build — tools.build entrypoint (clojure -T:build <task>). Canonical hive
  ;; build: jar / jar-aot / install / bump / verify-license / deploy.
  :build {:deps {io.github.clojure/tools.build {:mvn/version "0.10.9"}
                 slipset/deps-deploy {:mvn/version "0.2.2"}}
          :ns-default build}
:test {:extra-paths ["test"]
         :extra-deps {lambdaisland/kaocha {:mvn/version "1.91.1392"}
                      org.clojure/test.check {:mvn/version "1.1.1"}
                      io.github.hive-agi/hive-test {:mvn/version "0.3.9"}}}

  :dev {:extra-paths ["dev"]
        :extra-deps {nrepl/nrepl {:mvn/version "1.7.0"}
                     cider/cider-nrepl {:mvn/version "0.58.0"}}}}}
